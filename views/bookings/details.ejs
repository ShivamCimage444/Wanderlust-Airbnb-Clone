<% layout("/layouts/boilerplate") %>

<style>
  body {
    background: linear-gradient(180deg, #f0f2f5, #e2e6f0);
  }

  .glass {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-radius: 20px;
    box-shadow: 0 15px 40px rgba(0,0,0,.08);
  }

  .hover-lift {
    transition: all .3s ease;
  }
  .hover-lift:hover {
    transform: translateY(-4px);
    box-shadow: 0 25px 60px rgba(0,0,0,.12);
  }

  .section-title {
    font-weight: 600;
    letter-spacing: .4px;
  }

  /* ===== PRICE + PAYMENT CARD ===== */
  .price-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(0,0,0,.1);
    padding: 20px;
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .price-summary {
    margin-bottom: 20px;
  }

  .price-summary span {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-weight: 500;
    font-size: 0.95rem;
    color: #555;
  }

  .total-box {
    background: linear-gradient(135deg, #fe424d, #fe424d);
    color: #fff;
    text-align: center;
    padding: 18px;
    border-radius: 16px;
    font-weight: 700;
    font-size: 1.5rem;
    margin-bottom: 20px;
  }

  .payment-card {
    border: 1.5px solid #ddd;
    border-radius: 16px;
    padding: 12px 16px;
    cursor: pointer;
    transition: all .25s ease;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .payment-card:hover {
    border-color: #fe424d;
    background: #fe424d;
  }

  .payment-card input {
    accent-color: #fe424d;
  }

  .payment-box {
    margin-top: 12px;
  }

  .confirm-btn {
    background: #fe424d;
    color: #fff;
    border: none;
    padding: 14px;
    font-size: 1.05rem;
    font-weight: 600;
    border-radius: 16px;
    width: 100%;
    transition: all .3s ease;
  }

  .confirm-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(228, 66, 77, 0.35);
  }

  @media(max-width: 991px) {
    .price-card {
      position: relative;
      top: auto;
      margin-bottom: 20px;
    }
  }
</style>

<h2 class="fw-bold">Complete Your Booking</h2> <p class="text-muted">You're just one step away from confirming your stay ✨</p>
<div class="container my-5">
  <div class="row g-4">
    <!-- LEFT: Guest & Booking Details -->
    <div class="col-lg-8">
      <form id="bookingForm" action="/bookings/<%= booking._id %>/details" method="POST">
        <!-- Guest Details -->
        <div class="glass hover-lift p-4 mb-4">
          <h5 class="section-title mb-3">Guest Details</h5>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Full Name*</label>
              <input type="text" name="guest[fullName]" class="form-control" required
                value="<%= booking.guestDetails?.fullName || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Email*</label>
              <input type="email" name="guest[email]" class="form-control" required
                value="<%= user.email %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Phone*</label>
              <input type="tel" name="guest[phone]" class="form-control" required
                value="<%= booking.guestDetails?.phone || '' %>">
            </div>
          </div>
        </div>

        <!-- Booking Details -->
        <div class="glass hover-lift p-4 mb-4">
          <h5 class="section-title mb-3">Booking Details</h5>
          <div class="row g-3">
            <div class="col-md-3">
              <label class="form-label">Adults*</label>
              <input type="number" name="guest[adults]" class="form-control" min="1" max="2" required
                value="<%= booking.guestDetails?.adults || 1 %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Children</label>
              <input type="number" name="guest[children]" class="form-control" min="0" max="2"
                value="<%= booking.guestDetails?.children || 0 %>">
            </div>
          </div>
        </div>

        <!-- Room Preferences -->
        <div class="glass hover-lift p-4 mb-4">
          <h5 class="section-title mb-3">Room Preferences</h5>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">Room Type</label>
              <select name="guest[roomType]" class="form-select">
                <option value="non-smoking" <%= booking.guestDetails?.roomType === 'non-smoking' ? 'selected' : '' %>>Non-Smoking</option>
                <option value="smoking" <%= booking.guestDetails?.roomType === 'smoking' ? 'selected' : '' %>>Smoking</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Floor Preference</label>
              <select name="guest[floor]" class="form-select">
                <option value="No preference" <%= booking.guestDetails?.floor === 'No preference' ? 'selected' : '' %>>No preference</option>
                <option value="Low floor" <%= booking.guestDetails?.floor === 'Low floor' ? 'selected' : '' %>>Low floor</option>
                <option value="High floor" <%= booking.guestDetails?.floor === 'High floor' ? 'selected' : '' %>>High floor</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">View</label>
              <select name="guest[view]" class="form-select">
                <option value="No preference" <%= booking.guestDetails?.view === 'No preference' ? 'selected' : '' %>>No preference</option>
                <option value="City view" <%= booking.guestDetails?.view === 'City view' ? 'selected' : '' %>>City view</option>
                <option value="Garden view" <%= booking.guestDetails?.view === 'Garden view' ? 'selected' : '' %>>Garden view</option>
                <option value="Sea view" <%= booking.guestDetails?.view === 'Sea view' ? 'selected' : '' %>>Sea view</option>
              </select>
            </div>
          </div>
          <div class="mt-3">
            <label class="form-label">Special Requests</label>
            <textarea name="guest[specialRequests]" class="form-control" rows="3" placeholder="Allergies, extra bed, late check-in, etc."><%= booking.guestDetails?.specialRequests || '' %></textarea>
          </div>
        </div>

    </div>

    <!-- RIGHT: Price + Payment -->
    <div class="col-lg-4">
      <div class="price-card hover-lift">

        <!-- PRICE SUMMARY -->
        <div class="price-summary">
          <h5 class="mb-3"><%= booking.listing.title %></h5>
          <span><span>Nights</span><span><%= nights %></span></span>
          <span><span>Base Price</span><span>₹ <%= basePrice %></span></span>
          <span><span>GST (12%)</span><span>₹ <%= gstAmount %></span></span>
        </div>

        <div class="total-box">
          Total Payable: ₹ <%= totalPrice %>
        </div>

        <!-- PAYMENT METHODS -->
        <div class="payment-card" onclick="selectPayment('upi')">
  <input type="radio" name="paymentMethod" value="upi" required> 💸 UPI
</div>
<div class="payment-card" onclick="selectPayment('card')">
  <input type="radio" name="paymentMethod" value="card"> 💳 Card
</div>
<div class="payment-card" onclick="selectPayment('netbanking')">
  <input type="radio" name="paymentMethod" value="netbanking"> 🏦 Net Banking
</div>
        <div id="upi" class="payment-box d-none">
          <label class="form-label">UPI ID</label>
          <input type="text" name="upiId" class="form-control">
        </div>

        <div id="card" class="payment-box d-none">
          <label class="form-label">Card Number</label>
          <input type="text" name="card[number]" class="form-control mb-2">
          <div class="row g-2">
            <div class="col">
              <label class="form-label">Expiry</label>
              <input type="text" name="card[expiry]" class="form-control">
            </div>
            <div class="col">
              <label class="form-label">CVV</label>
              <input type="password" name="card[cvv]" class="form-control">
            </div>
          </div>
        </div>

        <div id="netbanking" class="payment-box d-none">
          <label class="form-label">Select Bank</label>
          <select name="bank" class="form-select">
            <option>SBI</option>
            <option>HDFC</option>
            <option>ICICI</option>
            <option>Axis</option>
          </select>
        </div>

        <!-- CONFIRM BUTTON -->
        <button form="bookingForm" type="submit" class="confirm-btn mt-3">
          Confirm & Pay Securely
        </button>
      </div>
    </div>

  </div>
</div>
 </form>

<script>
function selectPayment(method) {
  // Show payment div
  document.querySelectorAll(".payment-box").forEach(div => div.classList.add("d-none"));
  document.getElementById(method).classList.remove("d-none");

  // Check the radio button
  const radio = document.querySelector(`input[name="paymentMethod"][value="${method}"]`);
  if (radio) radio.checked = true;
}
</script>
