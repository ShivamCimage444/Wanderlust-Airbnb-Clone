<% layout("/layouts/boilerplate") %>
<link href="/public/css/style.css" rel="stylesheet" />

<style>
  body {
    background: linear-gradient(180deg, #f8f9ff, #eef1ff);
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(12px);
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(0,0,0,.08);
    transition: all .3s ease;
  }

  .glass-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 70px rgba(0,0,0,.12);
  }

  .page-title span {
    background: linear-gradient(135deg,  #fe424d,  #fe424d);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .status-badge {
    padding: 6px 14px;
    border-radius: 999px;
    font-size: .85rem;
    text-transform: capitalize;
  }

  .btn-gradient {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    border: none;
    color: #fff;
    padding: 8px 22px;
    border-radius: 999px;
    transition: all .3s ease;
  }

  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 30px rgba(34,197,94,.35);
  }

  .empty-box {
    background: rgba(255,255,255,.6);
    border-radius: 20px;
    padding: 50px;
    box-shadow: 0 20px 40px rgba(0,0,0,.06);
  }
</style>

<!-- ===== ALERT ===== -->
<div class="container mt-4">
  <div class="alert alert-danger glass-card d-flex justify-content-between align-items-center" role="alert">
    <div>
      <strong>⚠ NOTICE —</strong> Just coming before must verify your booking status
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
</div>

<div class="container my-5">

  <!-- ===== PAGE HEADING ===== -->
  <h2 class="fw-bold text-center my-4 page-title">
    My <span>Bookings</span>
  </h2>

  <% if (bookings.length === 0) { %>

    <!-- ===== EMPTY STATE ===== -->
    <div class="text-center mt-5">
      <div class="empty-box mx-auto" style="max-width:500px;">
        <h5 class="fw-semibold mb-2">No bookings yet</h5>
        <p class="text-muted fs-6 mb-0">
          You have not any bookings yet.
        </p>
      </div>
    </div>

  <% } else { %>

    <!-- ===== BOOKINGS LIST ===== -->
    <div class="row justify-content-center mt-4 g-4">
      <div class="col-lg-10">

        <% bookings.forEach(b => { %>

          <div class="glass-card mb-4">
            <div class="card-body p-4">

              <!-- TITLE -->
              <h5 class="fw-semibold mb-2">
                <%= b.listing.title %>
              </h5>

              <!-- STATUS -->
              <div class="mb-2">
                <span class="fw-semibold me-2">Status:</span>
                <span class="status-badge 
                  <%= b.status === "approved" ? "bg-success text-white" : 
                      b.status === "pending" ? "bg-warning text-dark" : "bg-secondary text-white" %>">
                  <%= b.status %>
                </span>
              </div>

              <!-- DATES -->
              <p class="text-muted mb-3">
                📅 <%= b.startDate.toDateString() %> → <%= b.endDate.toDateString() %>
              </p>

              <!-- ACTION -->
              <% if (b.status === "approved") { %>
                <a href="/bookings/<%= b._id %>/details" class="btn btn-gradient">
                  Fill Details & Pay →
                </a>
              <% } %>

            </div>
          </div>

        <% }) %>

      </div>
    </div>

  <% } %>

</div>
