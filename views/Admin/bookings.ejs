<% layout("/layouts/boilerplate") %>

<style>
  /* ===== PREMIUM ADMIN THEME ===== */
  body {
    background: linear-gradient(135deg, #f5f7fb, #eef2ff);
    color: #0f172a;
  }

  .container {
    max-width: 1250px;
  }

  /* ===== FILTER CARD LOOK ===== */
  form.row {
    background: #ffffff;
    padding: 18px;
    border-radius: 16px;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
  }

  label.form-label {
    font-size: 0.85rem;
    color: #334155;
  }

  .form-select {
    border-radius: 12px;
    border: 1px solid #e5e7eb;
  }

  .btn-dark {
    background: linear-gradient(135deg, #0f172a, #334155);
    border: none;
    border-radius: 12px;
    font-weight: 500;
  }

  /* ===== CARD ===== */
  .card {
    border: none;
    border-radius: 18px;
    overflow: hidden;
    background: #ffffff;
    box-shadow: 0 15px 35px rgba(15, 23, 42, 0.1);
  }

  .card-header {
    background: linear-gradient(135deg, #0f172a, #334155) !important;
    padding: 18px 22px;
  }

  .card-header h4 {
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  /* ===== TABLE ===== */
  table {
    margin-bottom: 0;
  }

  thead th {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    background-color: #f1f5f9 !important;
    color: #334155;
    text-align: center;
    padding: 14px;
  }

  tbody td {
    vertical-align: middle;
    padding: 16px;
    font-size: 0.9rem;
  }

  tbody tr {
    transition: all 0.25s ease;
  }

  tbody tr:hover {
    background-color: #eef2ff;
    transform: scale(1.003);
  }

  /* ===== LINKS ===== */
  a.text-decoration-none {
    color: #4f46e5;
  }

  a.text-decoration-none:hover {
    text-decoration: underline;
  }

  /* ===== BADGES ===== */
  .badge {
    font-size: 0.7rem;
    padding: 6px 12px;
    border-radius: 999px;
    font-weight: 500;
  }

  .bg-success {
    background: linear-gradient(135deg, #16a34a, #22c55e) !important;
  }

  .bg-primary {
    background: linear-gradient(135deg, #4f46e5, #6366f1) !important;
  }

  .bg-warning {
    background: linear-gradient(135deg, #f59e0b, #fbbf24) !important;
    color: #0f172a !important;
  }

  .bg-danger {
    background: linear-gradient(135deg, #dc2626, #ef4444) !important;
  }

  .bg-info {
    background: linear-gradient(135deg, #38bdf8, #0ea5e9) !important;
    color: #0f172a;
  }

  .bg-secondary {
    background: linear-gradient(135deg, #64748b, #475569) !important;
  }

  /* ===== BUTTONS ===== */
  .btn-outline-primary {
    border-radius: 10px;
    font-size: 0.75rem;
    padding: 6px 14px;
    border-color: #4f46e5;
    color: #4f46e5;
  }

  .btn-outline-primary:hover {
    background: #4f46e5;
    color: #ffffff;
  }

  /* ===== PAGINATION ===== */
  .pagination {
    margin-top: 30px;
  }

  .pagination .page-link {
    border-radius: 12px;
    margin: 0 4px;
    padding: 8px 14px;
    color: #334155;
    font-weight: 500;
  }

  .pagination .page-item.active .page-link {
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    border: none;
  }

  .page-item.disabled .page-link {
    color: #94a3b8;
  }
</style>

<div class="container my-4">

  <!-- FILTERS -->
  <form method="GET" class="row g-2 mb-4 align-items-end">
    <div class="col-md-3">
      <label class="form-label fw-semibold">Status</label>
      <select name="status" class="form-select">
        <option value="">All Status</option>
        <option value="pending" <%= selectedStatus==="pending"?"selected":"" %>>Pending</option>
        <option value="approved" <%= selectedStatus==="approved"?"selected":"" %>>Approved</option>
        <option value="confirmed" <%= selectedStatus==="confirmed"?"selected":"" %>>Confirmed</option>
        <option value="cancelled_by_owner" <%= selectedStatus==="cancelled_by_owner"?"selected":"" %>>
          Cancelled by Owner
        </option>
        <option value="cancelled_by_user" <%= selectedStatus==="cancelled_by_user"?"selected":"" %>>
          Cancelled by User
        </option>
      </select>
    </div>

    <div class="col-md-4">
      <label class="form-label fw-semibold">Owner</label>
      <select name="owner" class="form-select">
        <option value="">All Owners</option>
        <% owners.forEach(o => { %>
          <option value="<%= o._id %>" <%= selectedOwner==o._id?"selected":"" %>>
            <%= o.username %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="col-md-2">
      <button class="btn btn-dark w-100">Apply Filters</button>
    </div>
  </form>

  <!-- BOOKINGS TABLE -->
  <div class="card">
    <div class="card-header text-white">
      <h4 class="mb-0"> All Bookings</h4>
    </div>

    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="text-center">
          <tr>
            <th>User</th>
            <th>Listing</th>
            <th>Owner</th>
            <th>Dates</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>

        <tbody>
          <% if (bookings.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">
                No bookings found
              </td>
            </tr>
          <% } %>

          <% bookings.forEach(b => { 
            const nights =
              (new Date(b.endDate) - new Date(b.startDate)) /
              (1000 * 60 * 60 * 24);
            const total = b.listing?.price ? nights * b.listing.price : 0;
          %>

          <tr>
            <td class="text-center">
              <strong><%= b.user?.username || "Deleted User" %></strong><br>
              <small class="text-muted"><%= b.user?.email || "" %></small>
            </td>

            <td>
              <% if (b.listing) { %>
                <a href="/listings/<%= b.listing._id %>" class="fw-semibold text-decoration-none">
                  <%= b.listing.title %>
                </a>
              <% } else { %>
                <span class="text-muted">Deleted Listing</span>
              <% } %>
            </td>

            <td class="text-center">
              <%= b.listing?.owner?.username || "N/A" %>
            </td>

            <td class="text-center">
              <%= b.startDate.toDateString() %><br>
              <span class="text-muted">→</span><br>
              <%= b.endDate.toDateString() %>
            </td>

            <td class="text-center fw-bold">
              ₹ <%= total %>
            </td>

            <td class="text-center">
              <% if (b.status === "confirmed") { %>
                <span class="badge bg-success">Confirmed</span>
              <% } else if (b.status === "approved") { %>
                <span class="badge bg-primary">Approved</span>
              <% } else if (b.status === "pending") { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } else if (b.status === "cancelled_by_owner") { %>
                <span class="badge bg-danger">Cancelled by Owner</span>
              <% } else if (b.status === "cancelled_by_user") { %>
                <span class="badge bg-info">Cancelled by User</span>
              <% } else { %>
                <span class="badge bg-secondary"><%= b.status %></span>
              <% } %>
            </td>

            <td class="text-center">
              <a href="/admin/bookings/<%= b._id %>" class="btn btn-sm btn-outline-primary">
                View Details
              </a>
            </td>
          </tr>

          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Pagination -->
<nav aria-label="Bookings Pagination">
  <ul class="pagination justify-content-center mt-4">
    <% if(currentPage > 1){ %>
      <li class="page-item">
        <a class="page-link" href="?status=<%= selectedStatus %>&owner=<%= selectedOwner %>&page=<%= currentPage-1 %>">Previous</a>
      </li>
    <% } else { %>
      <li class="page-item disabled"><span class="page-link">Previous</span></li>
    <% } %>

    <% for(let i=1; i<=totalPages; i++){ %>
      <li class="page-item <%= currentPage === i ? 'active' : '' %>">
        <a class="page-link" href="?status=<%= selectedStatus %>&owner=<%= selectedOwner %>&page=<%= i %>"><%= i %></a>
      </li>
    <% } %>

    <% if(currentPage < totalPages){ %>
      <li class="page-item">
        <a class="page-link" href="?status=<%= selectedStatus %>&owner=<%= selectedOwner %>&page=<%= currentPage+1 %>">Next</a>
      </li>
    <% } else { %>
      <li class="page-item disabled"><span class="page-link">Next</span></li>
    <% } %>
  </ul>
</nav>
